
USE car_rental;

CREATE TABLE `users` (
  `id` int NOT NULL AUTO_INCREMENT,
  `full_name` varchar(100) DEFAULT NULL,
  `email` varchar(100) DEFAULT NULL,
  `phone` varchar(20) DEFAULT NULL,
  `role` enum('admin','employee','customer') NOT NULL,
  `password_hash` varchar(255) NOT NULL,
  `driving_license_no` varchar(50) DEFAULT NULL,
  `salary` decimal(10,2) DEFAULT NULL,
  PRIMARY KEY (`id`)
);
select * from users;
CREATE TABLE cars (
  id int NOT NULL AUTO_INCREMENT,
  brand varchar(50) DEFAULT NULL,
  model varchar(50) DEFAULT NULL,
  category varchar(50) DEFAULT NULL,
  year int DEFAULT NULL,
  status tinyint(1) DEFAULT '1',
  image_url varchar(255) DEFAULT NULL,
  PRIMARY KEY (id)
);


CREATE TABLE car_prices (
    id INT AUTO_INCREMENT PRIMARY KEY,
    car_id INT NOT NULL,
    day ENUM(
        'sunday',
        'monday',
        'tuesday',
        'wednesday',
        'thursday',
        'friday',
        'saturday'
    ) NOT NULL,
    price DECIMAL(10,2) NOT NULL,

    CONSTRAINT fk_car_prices_car
        FOREIGN KEY (car_id)
        REFERENCES cars(id)
        ON DELETE CASCADE,

    CONSTRAINT uq_car_day
        UNIQUE (car_id, day)
);


CREATE TABLE `rentals` (
  `id` int NOT NULL AUTO_INCREMENT,
  `user_id` int NOT NULL,
  `employee_id` int DEFAULT NULL,
  `car_id` int NOT NULL,
  `pickup_location` varchar(100) DEFAULT NULL,
  `dropoff_location` varchar(100) DEFAULT NULL,
  `start_date` datetime DEFAULT NULL,
  `end_date` datetime DEFAULT NULL,
  `total_price` decimal(10,2) DEFAULT NULL,
  `created_at` timestamp NULL DEFAULT CURRENT_TIMESTAMP,
  `status` varchar(20) NOT NULL DEFAULT 'pending',
  PRIMARY KEY (`id`),
  KEY `user_id` (`user_id`),
  KEY `employee_id` (`employee_id`),
  KEY `car_id` (`car_id`),
  CONSTRAINT `rentals_ibfk_1` FOREIGN KEY (`user_id`) REFERENCES `users` (`id`),
  CONSTRAINT `rentals_ibfk_2` FOREIGN KEY (`employee_id`) REFERENCES `users` (`id`),
  CONSTRAINT `rentals_ibfk_3` FOREIGN KEY (`car_id`) REFERENCES `cars` (`id`)
);

CREATE TABLE payments (
    id INT AUTO_INCREMENT PRIMARY KEY,
    rental_id INT NOT NULL,
    user_id INT NOT NULL,
    amount DECIMAL(10,2),
    payment_method VARCHAR(50),
    payment_status VARCHAR(50),
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,

    FOREIGN KEY (rental_id) REFERENCES rentals(id)
        ON DELETE CASCADE,
    FOREIGN KEY (user_id) REFERENCES users(id)
);

CREATE TABLE notifications (
    id INT AUTO_INCREMENT PRIMARY KEY,
    user_id INT NOT NULL,
    title VARCHAR(100),
    message TEXT,
    is_read BOOLEAN DEFAULT FALSE,
    created_at DATETIME DEFAULT CURRENT_TIMESTAMP,

    FOREIGN KEY (user_id)
        REFERENCES users(id)
        ON DELETE CASCADE
);


ALTER TABLE notifications
  ADD COLUMN rental_id INT NULL,
  ADD INDEX idx_notifications_user_read (user_id, is_read),
  ADD INDEX idx_notifications_rental (rental_id);

